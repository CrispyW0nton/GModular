# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyc

# Virtual environments
.venv/
venv/
env/
ENV/

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# App data / user config (do not commit personal game paths)
~/.gmodular/
.gmodular/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Temp / scratch
*.tmp
*.bak
/tmp/

# Core dumps (crash dumps from OS)
core
core.*
*.core
vgcore.*

# PyInstaller build output
dist/
*.spec.bak

# Logs
*.log
supervisord.log
supervisord.pid
supervisor.sock

# Environment / secrets (never commit these)
.env
.env.*
*.secret
secrets.json
credentials.json

# Render output images (generated by tools/render_*.py)
renders/*.ppm
renders/*.png

# KotOR game data (do not commit)
*.mod
*.erf
*.rim
*.mdl
*.mdx
*.tpc
*.tga
# Generated/extracted test artifacts
tests/test_data/_*/
=*
