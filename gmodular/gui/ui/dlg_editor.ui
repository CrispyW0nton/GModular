  <property name="styleSheet">
   <string notr="true">QWidget { background:#1e1e1e; color:#d4d4d4; }
QSplitter::handle { background:#3c3c3c; width:2px; }
QTreeView, QListView {
    background:#252526; border:none; color:#d4d4d4;
    selection-background-color:#094771;
}
QTreeView::item, QListView::item { padding:2px; }
QGroupBox {
    color:#9cdcfe; font-size:8pt; font-weight:bold;
    border:1px solid #3c3c3c; border-radius:3px;
    margin-top:8px; padding-top:4px;
}
QGroupBox::title { subcontrol-origin:margin; subcontrol-position:top left; padding:0 4px; }
QPlainTextEdit, QTextEdit {
    background:#252526; border:1px solid #3c3c3c; color:#d4d4d4;
    font-family:Consolas,monospace; font-size:9pt; border-radius:3px;
}
QLineEdit, QSpinBox, QComboBox {
    background:#3c3c3c; border:1px solid #555; border-radius:3px;
    color:#d4d4d4; padding:2px 4px; font-size:8pt;
}
QPushButton {
    background:#0e639c; color:#fff; border:none; border-radius:3px;
    padding:4px 12px; font-size:8pt;
}
QPushButton:hover { background:#1177bb; }
QLabel { color:#d4d4d4; }</string>
